# OPTIONAL: run the control-plane web app itself in a container (Ubuntu host).
# Default/recommended is to run it on the host via ./dev.sh — simpler, and on
# RunPod (native engine) it must be on the host anyway. Use this only if you
# want the manager containerized while it spawns model containers via the host
# docker daemon. Requires mounting the docker socket AND the host HF cache:
#
#   docker build -f Dockerfile.manager -t miniclosedai-llm-manager .
#   docker run -d --name miniclosedai-llm \
#     -p 8099:8099 \
#     -v /var/run/docker.sock:/var/run/docker.sock \
#     -v $HOME/.cache/huggingface:/root/.cache/huggingface \
#     --env-file .env -e LAUNCH_ENGINE=docker \
#     miniclosedai-llm-manager
#
# NOTE: model containers are still started on the HOST docker daemon (sibling
# containers), so their published ports (8001+) are reachable on the host. HF_HOME
# inside this container should match the host path you bind so weights are shared.
FROM python:3.12-slim

# docker CLI so the manager can talk to the mounted host daemon.
RUN apt-get update \
 && apt-get install -y --no-install-recommends docker.io curl \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY manager-requirements.txt .
RUN pip install --no-cache-dir -r manager-requirements.txt

COPY app.py model_manager.py _args.py models.yaml ./
COPY tests/ ./tests/
COPY static/ ./static/

ENV MANAGER_PORT=8099 HF_HOME=/root/.cache/huggingface
EXPOSE 8099
CMD ["sh", "-c", "uvicorn app:app --host 0.0.0.0 --port ${MANAGER_PORT}"]
