# Copy to .env and fill in.  `docker compose` auto-loads .env from this dir.
#   cp .env.example .env

# HuggingFace token — REQUIRED for gated repos (Qwen/InternVL are usually
# ungated, but a token avoids rate limits and is needed if you switch to a
# gated model). Get one at https://huggingface.co/settings/tokens (read scope).
HF_TOKEN=

# Where HuggingFace caches downloaded weights on the HOST. Mounted into the
# container so weights survive restarts and are shared across model services.
# Make sure this disk has room (an 8B model is ~16-20 GB; 32B FP8 ~35 GB).
HF_HOME=${HOME}/.cache/huggingface

# vLLM image tag. Pin to a specific release for reproducibility, e.g.
# vllm/vllm-openai:v0.11.0 . "latest" tracks the newest published image.
VLLM_IMAGE=vllm/vllm-openai:latest

# Optional API key to ENFORCE on the vLLM servers. If set non-empty, vLLM is
# launched with --api-key <this>, and you must enter the SAME value in the
# miniclosedai backend "API key" field. Leave blank to accept any key. Also passed
# to the llama.cpp server for GGUF models.
VLLM_API_KEY=

# ------------------------------------------------- GGUF / ternary (llama.cpp) ---
# GGUF models (ternary Bonsai etc.) are served by llama-server, auto-detected when
# you paste a GGUF repo. These are optional — the engine auto-discovers a binary.

# Path to a llama-server binary. Leave blank to auto-detect: ./.llamacpp build
# (from ./setup_llamacpp.sh) → the bonsai1bit_test build → PATH. Ternary (Q2_0)
# needs the PrismML fork build that setup_llamacpp.sh produces.
LLAMACPP_SERVER_BIN=

# LD_LIBRARY_PATH for the llama-server's bundled .so's (defaults to the binary's dir).
LLAMACPP_LIB_DIR=

# Where llama-server caches downloaded GGUFs. Defaults under HF_HOME so the
# dashboard's "Downloaded models" cache stays unified.
LLAMA_CACHE=

# ------------------------------------------------------------------ web GUI ---
# These configure the control-plane web app (app.py + ./dev.sh).

# Port the web GUI binds (0.0.0.0:MANAGER_PORT). Default 8099.
MANAGER_PORT=8099

# The `mc` CLI talks to the dashboard at MANAGER_URL; leave unset to use
# http://localhost:$MANAGER_PORT. Set it to reach a dashboard on another host,
# e.g. MANAGER_URL=http://192.168.0.110:8099
MANAGER_URL=

# Which engine launches models: auto | docker | native.
#   auto   -> Docker if its daemon+GPU are usable (Ubuntu host), else native.
#   docker -> always spawn vllm/vllm-openai containers.
#   native -> always run `vllm serve` as a subprocess (needs vLLM installed;
#             this is what RunPod pods use, since they have no docker daemon).
LAUNCH_ENGINE=auto

# Optional Bearer token to protect the GUI/API. If set, requests must send
# `Authorization: Bearer <this>`. Leave blank for trusted localhost/LAN use.
MANAGER_API_KEY=

# Host that OTHER machines use to reach this server (used to build the base_url
# shown for miniclosedai). Leave blank to auto-detect this box's LAN IP — set it
# only to force a specific hostname/IP, e.g. PUBLIC_HOST=192.168.0.110
PUBLIC_HOST=

# RunPod tip: set HF_HOME to the persistent volume so weights survive restarts,
# e.g.  HF_HOME=/workspace/hf-cache
